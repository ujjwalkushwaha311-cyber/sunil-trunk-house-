        * { margin: 0; padding: 0; box-sizing: border-box; font-family: Arial, sans-serif; }

body { background-color: #ffffff; color: #333; }

/* Top Bar */
.top-bar {
    background: #f8f9fa;
    padding: 8px 10%;
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    border-bottom: 1px solid #eee;
}
.top-icons i { margin-left: 15px; cursor: pointer; color: #555; }

/* Navbar */
.main-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 10%;
    background: #fff;
}
.logo img { height: 60px; }
.nav-links { display: flex; list-style: none; }
.nav-links li { margin-left: 25px; }
.nav-links a { text-decoration: none; color: #333; font-weight: 500; font-size: 14px; }
.nav-links a:hover { color: #d63031; }

/* Banner */
.main-banner img { width: 100%; height: auto; display: block; }

/* Trust Bar */
.trust-bar {
    display: flex;
    justify-content: space-around;
    padding: 15px 10%;
    background: #fff;
    border-bottom: 1px solid #eee;
    font-size: 12px;
    font-weight: bold;
}
.trust-item i { color: #000; margin-right: 5px; }

/* Categories */
.category-section { padding: 40px 10%; text-align: center; }
.section-title { font-size: 22px; margin-bottom: 30px; letter-spacing: 1px; color: #444; }

.category-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.cat-card { position: relative; border-radius: 20px; overflow: hidden; border: 1px solid #eee; }
.cat-card img { width: 100%; height: 350px; object-fit: cover; }

.cat-info {
    position: absolute; top: 20px; left: 20px; text-align: left;
}
.cat-info p { font-weight: bold; font-size: 18px; margin-bottom: 10px; }
.btn-explore { 
    display: inline-block; padding: 8px 20px; background: #fff; 
    border: 1px solid #333; text-decoration: none; color: #333; 
    border-radius: 20px; font-size: 12px; font-weight: bold;
}

/* WhatsApp Float */
.whatsapp-sticky {
    position: fixed; bottom: 30px; right: 30px; 
    background: #25D366; color: #fff; width: 60px; height: 60px;
    border-radius: 50%; display: flex; align-items: center; justify-content: center;
    font-size: 30px; box-shadow: 0 4px 10px rgba(0,0,0,0.2); text-decoration: none;
}

/* Container to make slider fit perfectly below header */
.hero-page-wrapper {
    width: 100%;
    margin-top: 0; 
}

/* Slider Section (Height increased to 90vh) */
.hero-slider-container {
    position: relative;
    width: 100%;
    height: 90vh; /* Large size */
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
}

.slider-content {
    width: 100%;
    height: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
}

.slide {
    display: none; /* JS will handle this */
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
}

.slide.active {
    display: flex;
    animation: fadeIn 0.5s;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

/* Container for the Large Image */
.img-box {
    width: 90%; 
    height: 85%; /* Focus area on image */
    display: flex;
    justify-content: center;
    align-items: center;
}

.img-box img {
    max-height: 100%; 
    width: auto;
    filter: drop-shadow(0px 20px 40px rgba(0,0,0,0.1));
}

/* Model Label Styling */
.slide-info {
    margin-top: 15px;
    padding: 10px 30px;
    background: rgba(245, 245, 245, 0.9);
    border-radius: 50px;
    font-weight: bold;
    color: #333;
    font-size: 16px;
    z-index: 5;
}

/* Buttons Styling */
.nav-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: white;
    color: #333;
    border: 1px solid #ddd;
    width: 50px;
    height: 50px;
    cursor: pointer;
    font-size: 20px;
    border-radius: 50%;
    z-index: 100;
    transition: 0.3s;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

.nav-btn:hover {
    background: #f8f8f8;
}

.prev { left: 5%; }
.next { right: 5%; }

/* Bottom Detail Strip Styling */
.trust-strip {
    background: #ffffff;
    padding: 20px 0;
    border-top: 1px solid #eee;
    width: 100%;
}

.strip-content {
    display: flex;
    justify-content: space-around;
    max-width: 1200px;
    margin: 0 auto;
    flex-wrap: wrap;
    gap: 15px;
}

.strip-item {
    font-size: 14px;
    font-weight: 500;
    color: #555;
    display: flex;
    align-items: center;
    gap: 10px;
}

.strip-item i {
    font-size: 18px;
    color: #d32f2f;
}

/* Responsive adjust for slider */
@media (max-width: 768px) {
    .hero-slider-container {
        height: 60vh; /* Smaller height on mobile */
    }
}